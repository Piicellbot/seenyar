    <!-- ============================================
    JAVASCRIPT - کامل با localStorage
    ============================================ -->
    <script>
        // ============================================================
        //  تنظیمات API - استفاده از localStorage به جای سرور
        // ============================================================
        const API_URL = 'localstorage';

        // ============================================================
        //  ADMIN CONFIG
        // ============================================================
        const ADMIN_CONFIG = {
            phone: '09109765104',
            password: '13801380',
            name: 'مدیر اصلی'
        };

        function isAdminUser(phone, password) {
            const cleanPhone = phone.replace(/\s/g, '').replace(/^0/, '');
            const adminPhone = ADMIN_CONFIG.phone.replace(/\s/g, '').replace(/^0/, '');
            return cleanPhone === adminPhone && password === ADMIN_CONFIG.password;
        }

        function checkAdminAccess() {
            const adminData = localStorage.getItem('admin_logged_in');
            if (adminData) {
                try {
                    const data = JSON.parse(adminData);
                    return data.isLoggedIn === true;
                } catch(e) {
                    return false;
                }
            }
            return false;
        }

        // ============================================================
        //  DATA - سرویس‌ها
        // ============================================================
        const data = {
            networks: [
                { id: 1, name: 'اینستاگرام', icon: 'fa-instagram', color: '#E4405F' },
                { id: 2, name: 'تلگرام', icon: 'fa-telegram', color: '#0088cc' },
                { id: 3, name: 'یوتیوب', icon: 'fa-youtube', color: '#FF0000' },
