    <div class="modal-overlay" id="orderOverlay"></div>
    <div class="order-modal" id="orderModal">
        <div class="handle"></div>
        <button class="close-modal" onclick="closeOrderModal()"><i class="fas fa-times"></i></button>
        <div class="modal-header">
            <div class="icon-box"><i class="fas fa-pen"></i></div>
            <div>
                <div class="modal-title" id="modalServiceName">ثبت سفارش</div>
                <div style="color: #6b7280; font-size: 0.75rem; font-weight: 300;" id="modalServiceDesc">اطلاعات را تکمیل کنید</div>
            </div>
        </div>
        <div class="modal-subtitle"><i class="fas fa-info-circle" style="color: #2563eb;"></i> لطفاً اطلاعات زیر را با دقت وارد کنید</div>
        <form id="orderForm" novalidate>
            <div class="form-row">
                <div class="form-group">
                    <label for="targetLink"><i class="fas fa-link"></i> لینک هدف <span style="color:#dc2626;">*</span></label>
                    <input type="url" class="form-control" id="targetLink" placeholder="https://instagram.com/your-post" required />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-sort-amount-up"></i> تعداد <span style="color:#dc2626;">*</span></label>
                    <div class="quantity-control">
                        <button type="button" id="qtyMinus"><i class="fas fa-minus"></i></button>
                        <input type="number" class="form-control" id="quantity" value="1000" min="50" max="100000" step="50" />
                        <button type="button" id="qtyPlus"><i class="fas fa-plus"></i></button>
                    </div>
                </div>
            </div>
            
            <div class="form-group" id="phoneFieldGroup">
                <label for="phoneNumber"><i class="fas fa-phone"></i> شماره تماس <span style="color:#dc2626;">*</span></label>
                <input type="tel" class="form-control" id="phoneNumber" placeholder="مثال: ۰۹۱۲۱۲۳۴۵۶۷" required />
                <div style="font-size: 0.65rem; color: #6b7280; margin-top: 4px; font-weight: 300;">
                    <i class="fas fa-info-circle"></i> برای اطلاع‌رسانی وضعیت سفارش
                </div>
            </div>
            
            <div class="form-group">
                <label for="description"><i class="fas fa-align-left"></i> توضیحات تکمیلی</label>
                <textarea class="form-control" id="description" rows="2" placeholder="نیازهای خاص خود را بنویسید..."></textarea>
            </div>
            
            <div class="order-summary">
                <div class="row"><span class="label"><i class="fas fa-tag"></i> سرویس</span><span class="value" id="summaryService">-</span></div>
                <div class="row"><span class="label"><i class="fas fa-share-alt"></i> شبکه</span><span class="value" id="summaryNetwork">-</span></div>
                <div class="row"><span class="label"><i class="fas fa-sort-amount-up"></i> تعداد</span><span class="value" id="summaryQuantity">۰</span></div>
                <div class="row"><span class="label"><i class="fas fa-coins"></i> قیمت هر ۱۰۰۰ عدد</span><span class="value" id="summaryPricePerThousand">-</span></div>
                <div class="row total"><span class="label"><i class="fas fa-coins"></i> قیمت کل</span><span class="value" id="summaryTotal">۰ تومان</span></div>
            </div>
            
            <button type="submit" class="btn-submit-order" id="submitBtn">
                <i class="fas fa-check-circle"></i> ثبت سفارش
            </button>
        </form>
    </div>

