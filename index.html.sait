                { id: 12, title: 'افزایش بازدید یوتیوب', desc: 'افزایش بازدید واقعی و ارگانیک ویدیوهای یوتیوب', icon: 'fa-eye', pricePerThousand: 350, min: 100, max: 100000, networkId: 3, network: 'یوتیوب', deliveryTime: '۴۸ ساعته', guarantee: 'ضمانت بازگشت وجه' },
                { id: 13, title: 'افزایش فالوور یوتیوب', desc: 'افزایش فالوور واقعی برای کانال‌های یوتیوب', icon: 'fa-user-plus', pricePerThousand: 400, min: 100, max: 100000, networkId: 3, network: 'یوتیوب', deliveryTime: '۴۸ ساعته', guarantee: 'ضمانت بازگشت وجه' },
            ],
            testimonials: [
                { name: 'احمد رضایی', text: 'سین‌یار واقعاً عالی کار میکنه! فالوورهای اینستاگرام با کیفیت عالی.', rating: 5, date: '۲ هفته پیش' },
                { name: 'سارا محمدی', text: 'ممبرهای تلگرام واقعی و با کیفیت بودن. کانالم خیلی خوب رشد کرد.', rating: 5, date: '۱ ماه پیش' },
                { name: 'علی کریمی', text: 'سریع‌ترین سرویس افزایش بازدید یوتیوب که تا حالا دیدم.', rating: 4, date: '۳ هفته پیش' },
                { name: 'مریم حسینی', text: 'کیفیت فالوورهای اینستاگرام عالی بود و قیمت مناسب.', rating: 5, date: '۱ هفته پیش' },
                { name: 'رضا علیزاده', text: 'پشتیبانی عالی و پاسخگو. سفارشم دقیقاً سر وقت تحویل شد.', rating: 4, date: '۲ روز پیش' },
            ]
        };

        // ============================================================
        //  ذخیره‌سازی در localStorage
        // ============================================================
        function getData(key) {
            try {
                const data = localStorage.getItem('sinyar_' + key);
                return data ? JSON.parse(data) : [];
            } catch { return []; }
        }

        function setData(key, data) {
            localStorage.setItem('sinyar_' + key, JSON.stringify(data));
        }

        // ============================================================
        //  STATE
        // ============================================================
        let currentFilter = null;
        let selectedService = null;
        let currentUser = null;
        let orders = getData('orders');
        let users = getData('users');
        let walletBalance = parseInt(localStorage.getItem('sinyar_wallet')) || 0;
        let transactions = getData('transactions');
        let charges = getData('charges');
        let receiptTimer = null;
        let receiptTimeout = null;
        let adminFilter = 'all';
        let selectedFile = null;
        let chargeAmount = 0;

        // ============================================================
        //  INIT
        // ============================================================
        window.addEventListener('load', function() {
            const fill = document.getElementById('loadingFill');
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 12;
                if (progress > 100) progress = 100;
                fill.style.width = progress + '%';
                if (progress === 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        document.getElementById('preloader').classList.add('hide');
                    }, 300);
                }
            }, 150);
            
            // ایجاد ادمین و کاربر تست
            initData();
            
            renderAll();
            updateWalletUI();
            updateAdminPanel();
            updateCartUI();
            checkUserLoggedIn();
            
            setTimeout(() => {
                document.querySelectorAll('.stat-number').forEach(el => {
                    const original = el.textContent;
                    const num = parseInt(original.replace(/,/g, ''));
                    if (!isNaN(num)) {
                        let current = 0;
                        const step = Math.ceil(num / 40);
                        const interval2 = setInterval(() => {
                            current += step;
                            if (current >= num) { current = num; clearInterval(interval2); }
                            el.textContent = current.toLocaleString() + '+';
                        }, 25);
                    }
                });
            }, 800);

            document.getElementById('orderOverlay').addEventListener('click', closeOrderModal);
            document.getElementById('orderDetailOverlay').addEventListener('click', function(e) {
                if (e.target === this) closeOrderDetail();
            });
            document.getElementById('chargeModalOverlay').addEventListener('click', function(e) {
                if (e.target === this) closeChargeModal();
            });
            document.getElementById('receiptUploadOverlay').addEventListener('click', function(e) {
                if (e.target === this) closeReceiptUpload();
            });

            document.getElementById('qtyMinus').addEventListener('click', function() {
                const input = document.getElementById('quantity');
                let val = parseInt(input.value) || 0;
                const min = selectedService ? selectedService.min : 50;
                val = Math.max(min, val - 50);
                input.value = val;
                updateSummary();
            });

            document.getElementById('qtyPlus').addEventListener('click', function() {
                const input = document.getElementById('quantity');
                let val = parseInt(input.value) || 0;
                const max = selectedService ? selectedService.max : 100000;
                val = Math.min(max, val + 50);
                input.value = val;
                updateSummary();
            });

            document.getElementById('quantity').addEventListener('input', updateSummary);

            document.getElementById('orderForm').addEventListener('submit', function(e) {
                e.preventDefault();
                submitOrder();
            });

            document.getElementById('chargeAmount').addEventListener('input', function() {
                const val = parseInt(this.value) || 0;
                document.getElementById('miniChargeAmount').textContent = formatPrice(val);
                document.querySelectorAll('.quick-amounts button').forEach(b => b.classList.remove('active'));
            });
        });

        // ============================================================
        //  INIT DATA
        // ============================================================
        function initData() {
            // چک کردن ادمین
            const adminExists = users.find(u => u.phone === '09109765104');
            if (!adminExists) {
                users.push({
                    id: Date.now() + 1,
                    full_name: 'مدیر اصلی',
                    phone: '09109765104',
                    email: 'admin@email.com',
                    password: '13801380',
                    wallet_balance: 0,
                    is_admin: true,
                    created_at: new Date().toISOString()
                });
                setData('users', users);
            }
            
            // چک کردن کاربر تست
            const testExists = users.find(u => u.phone === '09121234567');
            if (!testExists) {
                users.push({
                    id: Date.now() + 2,
                    full_name: 'کاربر تست',
                    phone: '09121234567',
                    email: 'test@email.com',
                    password: '12345678',
                    wallet_balance: 100000,
                    is_admin: false,
                    created_at: new Date().toISOString()
                });
                setData('users', users);
            }
        }

        // ============================================================
        //  UI UPDATE - بعد از لاگین/ثبت‌نام
        // ============================================================
        function updateUIForLoggedInUser() {
            const authLink = document.getElementById('authLink');
            const heroAuthBtn = document.getElementById('heroAuthBtn');
            const footerAuthLink = document.getElementById('footerAuthLink');
            
            if (authLink) authLink.style.display = 'none';
            if (heroAuthBtn) heroAuthBtn.style.display = 'none';
            if (footerAuthLink) footerAuthLink.style.display = 'none';
            
            if (currentUser) {
                walletBalance = currentUser.wallet_balance || 0;
                localStorage.setItem('sinyar_wallet', walletBalance.toString());
                updateWalletUI();
            }
        }

        function checkUserLoggedIn() {
            const savedUser = localStorage.getItem('sinyar_current_user');
            if (savedUser) {
                try {
                    currentUser = JSON.parse(savedUser);
                    users = getData('users');
                    const user = users.find(u => u.id === currentUser.id);
                    if (user) {
                        currentUser = user;
                        updateUIForLoggedInUser();
                    }
                } catch(e) {
                    currentUser = null;
                }
            }
            updatePhoneField();
            
            // اگر کاربر لاگین هست، صفحه رو بروز کن
            if (currentUser) {
                renderAll();
                updateWalletUI();
                updateAdminPanel();
            }
        }

        // ============================================================
        //  EVENT LISTENERS
        // ============================================================
        
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const fullName = document.getElementById('regFullName').value.trim();
            const phone = document.getElementById('regPhone').value.trim();
            const email = document.getElementById('regEmail').value.trim();
            const password = document.getElementById('regPassword').value;
            const confirm = document.getElementById('regPasswordConfirm').value;

            if (!fullName || !phone || !password) {
                showToast('لطفاً همه فیلدها را پر کنید', 'error');
                return;
            }
            if (password.length < 8) {
                showToast('رمز عبور باید حداقل ۸ کاراکتر باشد', 'error');
                return;
            }
            if (password !== confirm) {
                showToast('رمز عبور و تکرار آن مطابقت ندارند', 'error');
                return;
            }

            registerUserAPI({ full_name: fullName, phone, email, password });
        });

        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const phone = document.getElementById('loginPhone').value.trim();
            const password = document.getElementById('loginPassword').value;

            loginUserAPI({ phone, password });
        });

        document.getElementById('adminLoginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const phone = document.getElementById('adminPhone').value.trim();
            const password = document.getElementById('adminPassword').value;
            
            adminLoginAPI({ phone, password });
        });

        // ============================================================
        //  API FUNCTIONS (با localStorage)
        // ============================================================
        
        function registerUserAPI(data) {
            const full_name = data.full_name;
            const phone = data.phone;
            const email = data.email;
            const password = data.password;
            
            // چک تکراری
            if (users.find(u => u.phone === phone)) {
                showToast('این شماره قبلاً ثبت شده', 'error');
                return;
            }
            
            const user = {
                id: Date.now(),
                full_name,
                phone,
                email,
                password,
                wallet_balance: 10000,
                is_admin: phone === '09109765104',
                created_at: new Date().toISOString()
            };
            users.push(user);
            setData('users', users);
            
            currentUser = user;
            localStorage.setItem('sinyar_current_user', JSON.stringify(currentUser));
            updateUIForLoggedInUser();
            showToast('ثبت نام موفق!', 'success');
            navigateTo('home');
            renderAll();
            updateWalletUI();
            updateAdminPanel();
        }

        function loginUserAPI(data) {
            const phone = data.phone;
            const password = data.password;
            
            const user = users.find(u => u.phone === phone && u.password === password);
            
            if (!user) {
                showToast('شماره یا رمز اشتباه است', 'error');
                return;
            }
            
            currentUser = user;
            localStorage.setItem('sinyar_current_user', JSON.stringify(currentUser));
            updateUIForLoggedInUser();
            showToast('خوش آمدید!', 'success');
            navigateTo('home');
            renderAll();
            updateWalletUI();
            updateAdminPanel();
        }

        function adminLoginAPI(data) {
            const phone = data.phone;
            const password = data.password;
            
            const user = users.find(u => u.phone === phone && u.password === password && u.is_admin === true);
            
            if (!user) {
                showToast('اطلاعات ورود صحیح نیست', 'error');
                return;
            }
            
            localStorage.setItem('admin_logged_in', JSON.stringify({
                isLoggedIn: true,
                name: user.full_name,
                phone: user.phone
            }));
            
            currentUser = user;
            localStorage.setItem('sinyar_current_user', JSON.stringify(currentUser));
            showToast('به پنل مدیریت خوش آمدید', 'success');
            navigateTo('admin');
            renderAll();
            updateAdminPanel();
        }

        function createOrderAPI(data) {
            const tracking = 'SY-' + Date.now().toString().slice(-8) + Math.random().toString(36).slice(2, 6).toUpperCase();
            
            const order = {
                id: Date.now(),
                tracking_code: tracking,
                user_id: data.user_id,
                user_name: data.user_name,
                user_phone: data.user_phone,
                service: data.service,
                service_id: data.service_id,
                network: data.network,
                network_id: data.network_id,
                target_link: data.target_link,
                quantity: data.quantity,
                total_price: data.total_price,
                price_per_thousand: data.price_per_thousand,
                description: data.description || '',
                status: 'pending',
                created_at: new Date().toISOString()
            };
            
            orders.push(order);
            setData('orders', orders);
            
            // کاهش موجودی
            const userIndex = users.findIndex(u => u.id === data.user_id);
            if (userIndex !== -1) {
                users[userIndex].wallet_balance -= data.total_price;
                setData('users', users);
                // بروزرسانی currentUser
                currentUser = users[userIndex];
                localStorage.setItem('sinyar_current_user', JSON.stringify(currentUser));
            }
            
            return { success: true, message: 'سفارش ثبت شد', order: order };
        }

        function getOrdersAPI(userId) {
            let result = orders;
            if (userId) {
                result = orders.filter(o => o.user_id === userId);
            }
            return { success: true, orders: result };
        }

        function getWalletAPI(userId) {
            const user = users.find(u => u.id === userId);
            return { success: true, balance: user ? user.wallet_balance : 0 };
        }

        function chargeRequestAPI(data) {
            const charge = {
                id: Date.now(),
                user_id: data.user_id,
                user_name: data.user_name,
                user_phone: data.user_phone,
                amount: data.amount,
                status: 'pending',
                bank_card: data.bank_card || '6104338973526870',
                card_holder: data.card_holder || 'حسن زاده',
                file_name: data.file_name || '',
                file_size: data.file_size || '',
                created_at: new Date().toISOString()
            };
            charges.push(charge);
            setData('charges', charges);
            return { success: true, message: 'درخواست شارژ ثبت شد', charge: charge };
        }

        // ============================================================
        //  NAVIGATION
        // ============================================================
        function navigateTo(page) {
            const pages = ['home', 'services', 'networks', 'wallet', 'admin', 'auth', 'testimonials', 'admin-login'];
            
            if (page === 'admin') {
                if (!checkAdminAccess()) {
                    showToast('لطفاً ابتدا وارد پنل مدیریت شوید', 'error');
                    page = 'admin-login';
                }
            }
            
            if (page === 'admin-login' && checkAdminAccess()) {
                page = 'admin';
            }
            
            pages.forEach(p => {
                const el = document.getElementById('page-' + p);
                if (el) el.classList.remove('active');
            });
            
            const target = document.getElementById('page-' + page);
            if (target) target.classList.add('active');
            
            document.querySelectorAll('.bottom-nav .nav-item').forEach(item => {
                item.classList.remove('active');
                if (item.dataset.page === 'page-' + page) {
                    item.classList.add('active');
                }
            });
            
            if (page === 'services') renderServicesNew();
            if (page === 'networks') renderAllNetworks();
            if (page === 'admin' && checkAdminAccess()) {
                updateAdminPanel();
                document.getElementById('adminName').textContent = 'مدیر اصلی';
            }
            if (page === 'wallet') {
                updateWalletUI();
            }
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function openServices() {
            if (!currentUser) {
                showToast('لطفاً ابتدا ثبت‌نام یا وارد شوید', 'error');
                navigateTo('auth');
                return;
            }
            navigateTo('services');
        }

        function toggleFilter() {
            document.querySelector('.services-header-filter').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function updatePhoneField() {
            const phoneField = document.getElementById('phoneFieldGroup');
            if (currentUser) {
                phoneField.style.display = 'none';
            } else {
                phoneField.style.display = 'block';
            }
        }

        // ============================================================
        //  RENDER FUNCTIONS
        // ============================================================
        function renderAll() {
            renderNetworks();
            renderServicesNew();
            renderAllNetworks();
            renderFilterChips();
            renderQuickAccess();
            renderAllTestimonials();
            updateAdminPanel();
            updateWalletUI();
            updateCartUI();
            updateWalletTransactions();
        }

        function renderNetworks() {
            const container = document.getElementById('networksScroll');
            container.innerHTML = data.networks.map(n => `
                <div class="network-card-large" onclick="filterByNetwork(${n.id})">
                    <div class="icon-wrap" style="color: ${n.color}">
                        <i class="fab ${n.icon}"></i>
                    </div>
                    <h4>${n.name}</h4>
                    <div class="active-dot"></div>
                </div>
            `).join('');
        }

        function renderAllNetworks() {
            const container = document.getElementById('allNetworks');
            container.innerHTML = data.networks.map(n => `
                <div class="network-card" onclick="filterByNetwork(${n.id}); navigateTo('services')" style="flex: none; background:rgba(255,255,255,0.88); border-radius:16px; padding:14px 10px; text-align:center; box-shadow:0 2px 12px rgba(0,0,0,0.04); cursor:pointer; border:2px solid rgba(255,255,255,0.3);">
                    <span class="icon" style="font-size:2.2rem;color:${n.color};display:block;margin-bottom:4px;"><i class="fab ${n.icon}"></i></span>
                    <h4 style="font-size:0.7rem;font-weight:700;color:#1a1a2e;">${n.name}</h4>
                </div>
            `).join('');
        }

        function renderFilterChips() {
            const container = document.getElementById('filterChips');
            const networks = data.networks;
            container.innerHTML = `
                <div class="filter-chip ${!currentFilter ? 'active' : ''}" data-id="all" onclick="filterServices('all')">همه</div>
            ` + networks.map(n => `
                <div class="filter-chip ${currentFilter === n.id ? 'active' : ''}" data-id="${n.id}" onclick="filterServices(${n.id})">
                    <i class="fab ${n.icon}" style="font-size:0.7rem;margin-left:4px;"></i> ${n.name}
                </div>
            `).join('');
        }

        function renderServicesNew() {
            const container = document.getElementById('allServices');
            let services = data.services;
            if (currentFilter) services = services.filter(s => s.networkId === currentFilter);
            
            if (services.length === 0) {
                container.innerHTML = `
                    <div style="grid-column:1/-1; text-align:center; padding:40px 20px; background:rgba(255,255,255,0.8); border-radius:20px; border:2px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-search" style="font-size:2.5rem;color:#9ca3af;margin-bottom:12px;display:block;"></i>
                        <h3 style="color:#4b5563;font-size:0.9rem;font-family:'Rubik',sans-serif;font-weight:600;">هیچ سرویسی پیدا نشد</h3>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = services.map(s => {
                const network = data.networks.find(n => n.id === s.networkId);
                const color = network?.color || '#2563eb';
                const isFeatured = s.featured || false;
                const pricePerThousand = s.pricePerThousand || s.price || 0;
                return `
                    <div class="service-card-new ${isFeatured ? 'featured' : ''}" onclick="openOrderModal(${s.id})">
                        ${isFeatured ? '<div class="featured-badge"><i class="fas fa-star"></i> ویژه</div>' : ''}
                        <div class="service-icon" style="background:linear-gradient(135deg, ${color}, ${color}88);">
                            <i class="fas ${s.icon}"></i>
                        </div>
                        <div class="service-title">${s.title}</div>
                        <div class="service-desc">${s.desc}</div>
                        <div class="service-meta">
                            <span><i class="fas fa-clock"></i> ${s.deliveryTime}</span>
                            <span><i class="fas fa-shield-alt"></i> ${s.guarantee}</span>
                        </div>
                        <div class="service-footer">
                            <div>
                                <div class="service-price">${formatPrice(pricePerThousand)} <small>تومان / ۱۰۰۰ عدد</small></div>
                                <div class="service-rating"><i class="fas fa-star"></i> ${s.rating || '۴.۸'}</div>
                            </div>
                            <button class="btn-order-sm" onclick="event.stopPropagation(); openOrderModal(${s.id})">
                                <i class="fas fa-pen"></i> سفارش
                            </button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function filterServices(id) {
            currentFilter = id === 'all' ? null : id;
            renderFilterChips();
            renderServicesNew();
            const networkName = id !== 'all' ? data.networks.find(n => n.id === id)?.name : 'همه';
            showToast(id !== 'all' ? `نمایش سرویس‌های ${networkName}` : 'نمایش همه سرویس‌ها', 'info');
        }

        function filterByNetwork(id) {
            currentFilter = id;
            renderFilterChips();
            renderServicesNew();
            navigateTo('services');
            const networkName = data.networks.find(n => n.id === id)?.name;
            showToast(`نمایش سرویس‌های ${networkName}`, 'info');
        }

        function renderQuickAccess() {
            const container = document.getElementById('quickAccess');
            const items = [
                { icon: 'fa-user-plus', label: 'افزایش فالوور', color: '#E4405F' },
                { icon: 'fa-heart', label: 'افزایش لایک', color: '#dc2626' },
                { icon: 'fa-eye', label: 'افزایش ویو', color: '#2563eb' },
                { icon: 'fa-users', label: 'افزایش ممبر', color: '#059669' },
            ];
            container.innerHTML = items.map(item => `
                <div class="quick-item" onclick="openServices()">
                    <i class="fas ${item.icon}" style="color: ${item.color};"></i>
                    <span>${item.label}</span>
                </div>
            `).join('');
        }

        function renderAllTestimonials() {
            const container = document.getElementById('allTestimonials');
            container.innerHTML = data.testimonials.map(t => `
                <div style="background: rgba(255,255,255,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 16px; padding: 16px; border: 2px solid rgba(255,255,255,0.3); box-shadow: 0 2px 12px rgba(0,0,0,0.02);">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                        <div style="width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #7c3aed); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 1rem; font-family: 'Rubik', sans-serif;">${t.name.charAt(0)}</div>
                        <div>
                            <div style="font-weight: 700; font-size: 0.9rem; color: #1a1a2e; font-family: 'Rubik', sans-serif;">${t.name}</div>
                            <div style="color: #f59e0b; font-size: 0.7rem;">${'★'.repeat(t.rating)}${'☆'.repeat(5 - t.rating)} <span style="color: #9ca3af; font-weight: 400;">${t.date}</span></div>
                        </div>
                    </div>
                    <p style="font-size: 0.85rem; color: #6b7280; line-height: 1.7; font-weight: 300;">"${t.text}"</p>
                </div>
            `).join('');
        }

        // ============================================================
        //  WALLET FUNCTIONS
        // ============================================================
        function updateWalletUI() {
            const balance = currentUser ? currentUser.wallet_balance || 0 : 0;
            document.getElementById('walletAmount').textContent = formatPrice(balance);
            document.getElementById('walletWithdraw').textContent = formatPrice(balance);
            document.getElementById('walletTransactionsCount').textContent = transactions.length;
        }

        function updateWalletTransactions() {
            const container = document.getElementById('walletTransactions');
            if (transactions.length === 0) {
                container.innerHTML = `
                    <div class="empty-transactions">
                        <i class="fas fa-inbox"></i>
                        <span>هیچ تراکنشی ثبت نشده است</span>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = transactions.slice(0, 5).map(t => `
                <div class="transaction-item">
                    <div class="tx-icon ${t.type === 'charge' ? 'credit' : 'debit'}">
                        <i class="fas ${t.type === 'charge' ? 'fa-arrow-down' : 'fa-arrow-up'}"></i>
                    </div>
                    <div class="tx-info">
                        <div class="tx-title">${t.type === 'charge' ? 'شارژ کیف پول' : 'برداشت از کیف پول'}</div>
                        <div class="tx-date">${t.date ? t.date : new Date().toLocaleDateString('fa-IR')} ${t.time ? '- ' + t.time : ''}</div>
                    </div>
                    <div class="tx-amount ${t.type === 'charge' ? 'credit' : 'debit'}">
                        ${t.type === 'charge' ? '+' : '-'}${formatPrice(t.amount)} تومان
                    </div>
                </div>
            `).join('');
        }

        // ============================================================
        //  CHARGE FUNCTIONS
        // ============================================================
        function openChargeModal() {
            if (!currentUser) {
                showToast('لطفاً ابتدا وارد حساب خود شوید', 'error');
                navigateTo('auth');
                return;
            }
            document.getElementById('chargeModalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeChargeModal() {
            document.getElementById('chargeModalOverlay').classList.remove('active');
            document.body.style.overflow = '';
            document.getElementById('chargeAmount').value = '';
            document.querySelectorAll('.quick-amounts button').forEach(b => b.classList.remove('active'));
            document.getElementById('miniChargeAmount').textContent = '۰';
            document.getElementById('fileName').classList.remove('show');
            selectedFile = null;
        }

        function setChargeAmount(amount) {
            document.getElementById('chargeAmount').value = amount;
            document.querySelectorAll('.quick-amounts button').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.quick-amounts button').forEach(b => {
                if (parseInt(b.textContent.replace(/,/g, '')) === amount) {
                    b.classList.add('active');
                }
            });
            document.getElementById('miniChargeAmount').textContent = formatPrice(amount);
        }

        function proceedToUpload() {
            const amount = parseInt(document.getElementById('chargeAmount').value);
            
            if (!amount || amount < 1000) {
                showToast('مبلغ باید حداقل ۱,۰۰۰ تومان باشد', 'error');
                return;
            }

            chargeAmount = amount;
            closeChargeModal();
            
            document.getElementById('receiptUploadOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
            document.getElementById('uploadAmount').textContent = formatPrice(amount);
            document.getElementById('submitReceiptBtn').disabled = true;
            document.getElementById('fileName').classList.remove('show');
            selectedFile = null;
        }

        function closeReceiptUpload() {
            document.getElementById('receiptUploadOverlay').classList.remove('active');
            document.body.style.overflow = '';
            selectedFile = null;
        }

        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (file) {
                selectedFile = file;
                document.getElementById('fileName').textContent = '📎 ' + file.name;
                document.getElementById('fileName').classList.add('show');
                document.getElementById('submitReceiptBtn').disabled = false;
                showToast('فایل با موفقیت انتخاب شد', 'success');
            }
        }

        function submitReceipt() {
            if (!selectedFile) {
                showToast('لطفاً ابتدا فایل را انتخاب کنید', 'error');
                return;
            }

            const data = {
                user_id: currentUser.id,
                user_name: currentUser.full_name,
                user_phone: currentUser.phone,
                amount: chargeAmount,
                bank_card: '6104338973526870',
                card_holder: 'حسن زاده',
                file_name: selectedFile.name,
                file_size: (selectedFile.size / 1024).toFixed(1) + ' KB'
            };

            const result = chargeRequestAPI(data);
            
            transactions.push({
                id: Date.now(),
                type: 'charge',
                amount: chargeAmount,
                date: new Date().toLocaleDateString('fa-IR'),
                time: new Date().toLocaleTimeString('fa-IR'),
                status: 'pending',
                userName: currentUser.full_name,
                description: 'درخواست شارژ'
            });
            setData('transactions', transactions);

            closeReceiptUpload();
            document.getElementById('chargeAmount').value = '';
            document.querySelectorAll('.quick-amounts button').forEach(b => b.classList.remove('active'));

            showToast(`درخواست شارژ ${formatPrice(chargeAmount)} تومان ثبت شد. منتظر تایید باشید`, 'success');
            updateWalletUI();
            updateWalletTransactions();
            updateAdminPanel();
        }

        // ============================================================
        //  ADMIN PANEL
        // ============================================================
        function updateAdminPanel() {
            if (!checkAdminAccess()) {
                return;
            }

            const totalOrders = orders.length;
            const totalUsers = users.length;
            const totalRevenue = orders.reduce((sum, o) => sum + o.total_price, 0);
            const pendingOrders = orders.filter(o => o.status === 'pending').length;
            const completedOrders = orders.filter(o => o.status === 'completed').length;

            document.getElementById('adminTotalOrders').textContent = totalOrders;
            document.getElementById('adminTotalUsers').textContent = totalUsers;
            document.getElementById('adminTotalRevenue').textContent = formatPrice(totalRevenue);
            document.getElementById('adminPendingOrders').textContent = pendingOrders;
            document.getElementById('adminCompletedOrders').textContent = completedOrders;

            document.getElementById('adminName').textContent = 'مدیر اصلی';

            renderAdminOrders();
        }

        function renderAdminOrders() {
            if (!checkAdminAccess()) {
                return;
            }

            const container = document.getElementById('adminOrderList');
            let filteredOrders = orders;
            
            if (adminFilter === 'pending') {
                filteredOrders = orders.filter(o => o.status === 'pending');
            } else if (adminFilter === 'processing') {
                filteredOrders = orders.filter(o => o.status === 'processing');
            } else if (adminFilter === 'completed') {
                filteredOrders = orders.filter(o => o.status === 'completed');
            } else if (adminFilter === 'canceled') {
                filteredOrders = orders.filter(o => o.status === 'canceled');
            }

            if (filteredOrders.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; color: #9ca3af; padding: 40px 0; font-weight: 300;">
                        <i class="fas fa-inbox" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                        هیچ سفارشی در این دسته وجود ندارد
                    </div>
                `;
                return;
            }

            container.innerHTML = filteredOrders.map(o => `
                <div class="admin-order-card" onclick="openOrderDetail('${o.tracking_code}')">
                    <div class="order-header">
                        <span class="order-tracking"><i class="fas fa-hashtag"></i> ${o.tracking_code}</span>
                        <span class="order-status ${o.status}"><i class="fas ${o.status === 'pending' ? 'fa-clock' : o.status === 'processing' ? 'fa-spinner' : o.status === 'completed' ? 'fa-check-circle' : 'fa-times-circle'}"></i> ${getStatusText(o.status)}</span>
                    </div>
                    <div class="order-details">
                        <div class="detail-item"><i class="fas fa-user"></i> ${o.user_name}</div>
                        <div class="detail-item"><i class="fas fa-tag"></i> ${o.service}</div>
                        <div class="detail-item"><i class="fas fa-share-alt"></i> ${o.network}</div>
                        <div class="detail-item"><i class="fas fa-sort-amount-up"></i> ${formatNumber(o.quantity)} عدد</div>
                        <div class="detail-item"><i class="fas fa-coins"></i> ${formatPrice(o.total_price)} تومان</div>
                        <div class="detail-item"><i class="fas fa-calendar"></i> ${o.created_at ? new Date(o.created_at).toLocaleDateString('fa-IR') : '۱۴۰۴/۰۱/۱۵'}</div>
                    </div>
                    <div class="order-actions" onclick="event.stopPropagation();">
                        <button class="btn-copy" onclick="copyText('${o.target_link}')">
                            <i class="fas fa-copy"></i> کپی لینک
                        </button>
                        <button class="btn-copy" onclick="copyText('${o.quantity}')">
                            <i class="fas fa-copy"></i> کپی تعداد
                        </button>
                        ${o.status === 'pending' ? `
                            <button class="btn-confirm" onclick="confirmOrder('${o.tracking_code}')">
                                <i class="fas fa-check"></i> تایید
                            </button>
                            <button class="btn-cancel" onclick="cancelOrder('${o.tracking_code}')">
                                <i class="fas fa-times"></i> لغو
                            </button>
                        ` : ''}
                        ${o.status === 'processing' ? `
                            <button class="btn-confirm" onclick="completeOrder('${o.tracking_code}')">
                                <i class="fas fa-check-double"></i> تکمیل
                            </button>
                        ` : ''}
                        <button class="btn-view-detail" onclick="openOrderDetail('${o.tracking_code}')">
                            <i class="fas fa-eye"></i> جزئیات
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function filterAdminOrders(status) {
            adminFilter = status;
            document.querySelectorAll('#filterAll, #filterPending, #filterCompleted').forEach(el => {
                if (el) el.style.opacity = '0.5';
            });
            const map = { all: 'filterAll', pending: 'filterPending', completed: 'filterCompleted' };
            if (map[status] && document.getElementById(map[status])) {
                document.getElementById(map[status]).style.opacity = '1';
            }
            renderAdminOrders();
        }

        function getStatusText(status) {
            const map = { pending: 'در انتظار', processing: 'در حال انجام', completed: 'تکمیل شده', canceled: 'لغو شده' };
            return map[status] || status;
        }

        function formatPrice(price) {
            return price.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        }

        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        }

        // ============================================================
        //  ORDER FUNCTIONS
        // ============================================================
        function openOrderModal(serviceId) {
            if (!currentUser) {
                showToast('لطفاً ابتدا ثبت‌نام یا وارد شوید', 'error');
                navigateTo('auth');
                return;
            }
            
            if (currentUser.wallet_balance < 1000) {
                showToast('موجودی کیف پول شما کافی نیست. لطفاً شارژ کنید.', 'error');
                navigateTo('wallet');
                return;
            }
            
            if (serviceId) {
                selectedService = data.services.find(s => s.id === serviceId);
                if (!selectedService) {
                    showToast('سرویس مورد نظر یافت نشد', 'error');
                    return;
                }
                document.getElementById('modalServiceName').textContent = selectedService.title;
                document.getElementById('modalServiceDesc').textContent = selectedService.desc;
                document.getElementById('summaryService').textContent = selectedService.title;
                document.getElementById('summaryNetwork').textContent = selectedService.network;
                const min = selectedService.min || 50;
                document.getElementById('quantity').value = min;
                updateSummary();
                updatePhoneField();
            }
            document.getElementById('orderOverlay').classList.add('active');
            document.getElementById('orderModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeOrderModal() {
            document.getElementById('orderOverlay').classList.remove('active');
            document.getElementById('orderModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        function updateSummary() {
            const quantity = parseInt(document.getElementById('quantity').value) || 0;
            document.getElementById('summaryQuantity').textContent = formatNumber(quantity);
            
            if (selectedService) {
                const pricePerThousand = selectedService.pricePerThousand || selectedService.price || 0;
                const total = Math.round((pricePerThousand * quantity) / 1000);
                document.getElementById('summaryPricePerThousand').textContent = formatPrice(pricePerThousand) + ' تومان';
                document.getElementById('summaryTotal').textContent = formatPrice(total) + ' تومان';
            } else {
                document.getElementById('summaryPricePerThousand').textContent = '-';
                document.getElementById('summaryTotal').textContent = '۰ تومان';
            }
        }

        function submitOrder() {
            const targetLink = document.getElementById('targetLink').value.trim();
            const quantity = parseInt(document.getElementById('quantity').value) || 0;
            const description = document.getElementById('description').value.trim();
            
            let phoneNumber = '';
            if (currentUser) {
                phoneNumber = currentUser.phone || '';
            } else {
                phoneNumber = document.getElementById('phoneNumber').value.trim();
            }
            
            if (!selectedService) {
                showToast('لطفاً یک سرویس انتخاب کنید', 'error');
                return;
            }

            if (!targetLink || !isValidUrl(targetLink)) {
                showToast('لطفاً لینک معتبر وارد کنید', 'error');
                return;
            }
            
            const min = selectedService.min || 50;
            const max = selectedService.max || 100000;
            if (quantity < min || quantity > max) {
                showToast(`تعداد باید بین ${formatNumber(min)} تا ${formatNumber(max)} باشد`, 'error');
                return;
            }
            
            if (!currentUser && (!phoneNumber || phoneNumber.length < 10)) {
                showToast('لطفاً شماره تماس معتبر وارد کنید', 'error');
                return;
            }
            
            const pricePerThousand = selectedService.pricePerThousand || selectedService.price || 0;
            const totalPrice = Math.round((pricePerThousand * quantity) / 1000);
            
            if (currentUser.wallet_balance < totalPrice) {
                showToast('موجودی کیف پول شما برای ثبت این سفارش کافی نیست', 'error');
                navigateTo('wallet');
                return;
            }
            
            const trackingCode = 'SY-' + Date.now().toString().slice(-8) + Math.random().toString(36).slice(2, 6).toUpperCase();
            
            const orderData = {
                user_id: currentUser ? currentUser.id : null,
                user_name: currentUser ? currentUser.full_name : 'کاربر مهمان',
                user_phone: phoneNumber,
                service: selectedService.title,
                service_id: selectedService.id,
                network: selectedService.network,
                network_id: selectedService.networkId,
                target_link: targetLink,
                quantity: quantity,
                total_price: totalPrice,
                price_per_thousand: pricePerThousand,
                description: description || ''
            };

            const result = createOrderAPI(orderData);
            
            if (result.success) {
                transactions.push({
                    id: Date.now(),
                    type: 'order',
                    amount: totalPrice,
                    date: new Date().toLocaleDateString('fa-IR'),
                    time: new Date().toLocaleTimeString('fa-IR'),
                    description: selectedService.title,
                    status: 'completed'
                });
                setData('transactions', transactions);
                
                showReceipt(result.order);
                closeOrderModal();
                document.getElementById('orderForm').reset();
                document.getElementById('quantity').value = selectedService?.min || 50;
                updateSummary();
                updateAdminPanel();
                updateCartUI();
                updateWalletUI();
                updateWalletTransactions();
                showToast(`سفارش شما با کد ${result.order.tracking_code} ثبت شد`, 'success');
            } else {
                showToast(result.message || 'خطا در ثبت سفارش', 'error');
            }
        }

        function confirmOrder(trackingCode) {
            const orderIndex = orders.findIndex(o => o.tracking_code === trackingCode);
            if (orderIndex === -1) return;
            
            if (orders[orderIndex].status === 'pending') {
                orders[orderIndex].status = 'processing';
                setData('orders', orders);
                updateAdminPanel();
                showToast(`سفارش ${trackingCode} تایید شد و در حال انجام است`, 'success');
            } else {
                showToast('این سفارش قبلاً تایید شده است', 'warning');
            }
        }

        function completeOrder(trackingCode) {
            const orderIndex = orders.findIndex(o => o.tracking_code === trackingCode);
            if (orderIndex === -1) return;
            
            if (orders[orderIndex].status === 'processing') {
                orders[orderIndex].status = 'completed';
                setData('orders', orders);
                updateAdminPanel();
                showToast(`سفارش ${trackingCode} با موفقیت تکمیل شد!`, 'success');
            } else {
                showToast('این سفارش قابل تکمیل نیست', 'warning');
            }
        }

        function cancelOrder(trackingCode) {
            const orderIndex = orders.findIndex(o => o.tracking_code === trackingCode);
            if (orderIndex === -1) return;
            
            if (orders[orderIndex].status === 'pending') {
                orders[orderIndex].status = 'canceled';
                setData('orders', orders);
                
                // برگرداندن پول به کاربر
                const userIndex = users.findIndex(u => u.id === orders[orderIndex].user_id);
                if (userIndex !== -1) {
                    users[userIndex].wallet_balance += orders[orderIndex].total_price;
                    setData('users', users);
                    if (currentUser && currentUser.id === users[userIndex].id) {
                        currentUser = users[userIndex];
                        localStorage.setItem('sinyar_current_user', JSON.stringify(currentUser));
                    }
                }
                
                updateAdminPanel();
                updateWalletUI();
                showToast(`سفارش ${trackingCode} لغو شد و مبلغ برگشت داده شد`, 'error');
            } else {
                showToast('این سفارش قابل لغو نیست', 'warning');
            }
        }

        // ============================================================
        //  ORDER DETAIL
        // ============================================================
        function openOrderDetail(trackingCode) {
            const order = orders.find(o => o.tracking_code === trackingCode);
            if (!order) {
                showToast('سفارش یافت نشد', 'error');
                return;
            }

            const overlay = document.getElementById('orderDetailOverlay');
            const body = document.getElementById('detailBody');
            const actions = document.getElementById('detailActions');
            
            document.getElementById('detailTitle').textContent = `جزئیات سفارش ${order.tracking_code}`;
            document.getElementById('detailSubtitle').textContent = `ثبت شده در ${order.created_at ? new Date(order.created_at).toLocaleDateString('fa-IR') : 'تاریخ نامشخص'}`;

            body.innerHTML = `
                <div class="detail-row"><span class="label">سرویس</span><span class="value highlight">${order.service}</span></div>
                <div class="detail-row"><span class="label">شبکه</span><span class="value">${order.network}</span></div>
                <div class="detail-row"><span class="label">کاربر</span><span class="value">${order.user_name}</span></div>
                <div class="detail-row"><span class="label">شماره تماس</span><span class="value">${order.user_phone}</span></div>
                <div class="detail-row"><span class="label">لینک هدف</span><span class="value" style="font-size:0.75rem;word-break:break-all;">${order.target_link}</span></div>
                <div class="detail-row"><span class="label">تعداد</span><span class="value">${formatNumber(order.quantity)} عدد</span></div>
                <div class="detail-row"><span class="label">قیمت هر ۱۰۰۰ عدد</span><span class="value">${formatPrice(order.price_per_thousand)} تومان</span></div>
                <div class="detail-row"><span class="label">قیمت کل</span><span class="value highlight">${formatPrice(order.total_price)} تومان</span></div>
                <div class="detail-row"><span class="label">وضعیت</span><span class="value"><span class="order-status ${order.status}"><i class="fas ${order.status === 'pending' ? 'fa-clock' : order.status === 'processing' ? 'fa-spinner' : order.status === 'completed' ? 'fa-check-circle' : 'fa-times-circle'}"></i> ${getStatusText(order.status)}</span></span></div>
                ${order.description && order.description !== 'ندارد' ? `<div class="detail-row"><span class="label">توضیحات</span><span class="value">${order.description}</span></div>` : ''}
            `;

            actions.innerHTML = `
                <button class="btn-copy" onclick="copyText('${order.target_link}')">
                    <i class="fas fa-copy"></i> کپی لینک
                </button>
                <button class="btn-copy" onclick="copyText('${order.quantity}')">
                    <i class="fas fa-copy"></i> کپی تعداد
                </button>
                ${order.status === 'pending' ? `
                    <button class="btn-confirm" onclick="confirmOrder('${order.tracking_code}'); closeOrderDetail();">
                        <i class="fas fa-check"></i> تایید سفارش
                    </button>
                    <button class="btn-cancel" onclick="cancelOrder('${order.tracking_code}'); closeOrderDetail();">
                        <i class="fas fa-times"></i> لغو سفارش
                    </button>
                ` : ''}
                ${order.status === 'processing' ? `
                    <button class="btn-confirm" onclick="completeOrder('${order.tracking_code}'); closeOrderDetail();">
                        <i class="fas fa-check-double"></i> تکمیل سفارش
                    </button>
                ` : ''}
                <button class="btn-view-detail" onclick="closeOrderDetail()" style="flex:1;padding:10px;border-radius:12px;font-weight:600;font-size:0.85rem;background:rgba(37,99,235,0.08);color:#2563eb;border:1px solid rgba(37,99,235,0.1);">
                    <i class="fas fa-times"></i> بستن
                </button>
            `;

            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeOrderDetail() {
            document.getElementById('orderDetailOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        // ============================================================
        //  RECEIPT
        // ============================================================
        function showReceipt(order) {
            const overlay = document.getElementById('receiptOverlay');
            const body = document.getElementById('receiptBody');
            const tracking = document.getElementById('receiptTracking');
            
            tracking.textContent = order.tracking_code;
            
            body.innerHTML = `
                <div class="row"><span class="label">تاریخ</span><span class="value">${order.created_at ? new Date(order.created_at).toLocaleDateString('fa-IR') : 'امروز'}</span></div>
                <div class="row"><span class="label">سرویس</span><span class="value highlight">${order.service}</span></div>
                <div class="row"><span class="label">شبکه</span><span class="value">${order.network}</span></div>
                <div class="row"><span class="label">تعداد</span><span class="value">${formatNumber(order.quantity)}</span></div>
                <div class="row"><span class="label">نام کاربر</span><span class="value">${order.user_name}</span></div>
                <div class="row"><span class="label">شماره تماس</span><span class="value">${order.user_phone}</span></div>
                <div class="row total"><span class="label">مبلغ قابل پرداخت</span><span class="value">${formatPrice(order.total_price)} تومان</span></div>
            `;
            
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            let seconds = 10;
            const timerEl = document.getElementById('receiptTimer');
            const closeBtn = document.getElementById('closeReceiptBtn');
            
            clearInterval(receiptTimer);
            clearTimeout(receiptTimeout);
            timerEl.textContent = seconds;
            
            receiptTimer = setInterval(() => {
                seconds--;
                timerEl.textContent = seconds;
                if (seconds <= 0) {
                    clearInterval(receiptTimer);
                    closeBtn.innerHTML = '<i class="fas fa-check"></i> بستن';
                }
            }, 1000);
            
            closeBtn.onclick = function() {
                clearInterval(receiptTimer);
                clearTimeout(receiptTimeout);
                closeReceipt();
            };
            
            receiptTimeout = setTimeout(() => {
                closeReceipt();
            }, 10000);
        }

        function closeReceipt() {
            document.getElementById('receiptOverlay').classList.remove('active');
            document.body.style.overflow = '';
            clearInterval(receiptTimer);
            clearTimeout(receiptTimeout);
        }

        // ============================================================
        //  CART
        // ============================================================
        function updateCartUI() {
            const count = cart.reduce((sum, item) => sum + item.quantity, 0);
            document.getElementById('cartCount').textContent = count;
        }

        // ============================================================
        //  CONTACT FUNCTIONS
        // ============================================================
        function openInstagram(username) {
            const url = `https://www.instagram.com/${username}/`;
            window.open(url, '_blank');
            showToast(`در حال باز کردن اینستاگرام ${username}...`, 'info');
        }

        function openTelegram(username) {
            const url = `https://t.me/${username}`;
            window.open(url, '_blank');
            showToast(`در حال باز کردن تلگرام ${username}...`, 'info');
        }

        function openEmail(email) {
            const url = `mailto:${email}`;
            window.open(url, '_blank');
            showToast(`در حال باز کردن ایمیل ${email}...`, 'info');
        }

        // ============================================================
        //  UTILITY
        // ============================================================
        function isValidUrl(string) {
            try { 
                const url = new URL(string); 
                return url.protocol === 'http:' || url.protocol === 'https:'; 
            } catch (_) { 
                return false; 
            }
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const msg = document.getElementById('toastMessage');
            msg.textContent = message;
            toast.className = `toast ${type}`;
            toast.classList.add('show');
            if (type === 'success') icon.className = 'fas fa-check-circle';
            else if (type === 'error') icon.className = 'fas fa-times-circle';
            else if (type === 'warning') icon.className = 'fas fa-exclamation-triangle';
            else icon.className = 'fas fa-info-circle';
            clearTimeout(toast._timeout);
            toast._timeout = setTimeout(() => toast.classList.remove('show'), 4000);
        }

        function copyCode() {
            const code = 'FIRST5';
            copyText(code);
            showToast('کد تخفیف FIRST5 کپی شد!', 'success');
        }

        function copyText(text) {
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(() => {
                    showToast('متن با موفقیت کپی شد', 'success');
                }).catch(() => {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            showToast('متن با موفقیت کپی شد', 'success');
        }

        function exportOrders() {
            if (orders.length === 0) {
                showToast('هیچ سفارشی برای خروجی وجود ندارد', 'error');
                return;
            }
            let csv = 'کد پیگیری,کاربر,سرویس,تعداد,قیمت کل,وضعیت,تاریخ\n';
            orders.forEach(o => {
                csv += `${o.tracking_code},${o.user_name},${o.service},${o.quantity},${o.total_price},${getStatusText(o.status)},${o.created_at ? new Date(o.created_at).toLocaleDateString('fa-IR') : ''}\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `sinyar_orders_${new Date().toISOString().slice(0,10)}.csv`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('خروجی با موفقیت دانلود شد', 'success');
        }

        function adminLogout() {
            localStorage.removeItem('admin_logged_in');
            showToast('خروج از پنل مدیریت', 'info');
            navigateTo('home');
        }

        // ============================================================
        //  HEADER SCROLL
        // ============================================================
        window.addEventListener('scroll', () => {
            const header = document.getElementById('header');
            header.classList.toggle('scrolled', window.scrollY > 20);
        });

        // ============================================================
        //  DARK MODE TOGGLE
        // ============================================================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'd' && e.ctrlKey) {
                document.body.classList.toggle('dark-mode');
                showToast(document.body.classList.contains('dark-mode') ? 'حالت شب فعال شد' : 'حالت روز فعال شد', 'info');
            }
        });

        console.log('🚀 سین‌یار نسخه نهایی - با localStorage');
        console.log('👑 ادمین: 09109765104 | رمز: 13801380');
        console.log('🧪 کاربر تست: 09121234567 | رمز: 12345678');
        console.log('📋 همه داده‌ها در مرورگر شما ذخیره میشوند');
        console.log('📱 سرویس جدید: ویو پست اینستاگرام - ۱,۶۸۰ تومان');
        console.log('🔒 ثبت سفارش فقط برای کاربران لاگین شده با موجودی کافی');
    </script>
</body>
</html>